# ── Flask ─────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-secret-string
FLASK_CONFIG=production

# ── Database (leave blank to use SQLite) ──────────────────────
DATABASE_URL=

# ── Google OAuth (leave blank to disable) ────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── AWS S3 (leave blank to use local disk) ────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# ── Internal service URLs (used by Docker Compose) ────────────
BACKEND_URL=http://backend:8000
CALLBACK_URL=http://frontend:5000
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
